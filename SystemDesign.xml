        <mxCell id="CL-EyrIyd61JyPVlWhIY-52" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;align=left;" value="&lt;div style=&quot;line-height: 170%;&quot;&gt;&lt;p style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-size: 30px; line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;System Design Cheat Sheet&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;p style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Problem&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Define the business problem, target users, and primary use cases.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Functional Requirements&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Specify the features and capabilities the system must provide.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Non-Functional Requirements&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Define scalability, availability, latency, security, reliability, and other quality attributes.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Scale&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Estimate users, requests per second (RPS), storage, bandwidth, and projected growth.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Domain Modeling&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Identify core entities, relationships, and business rules.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Architecture&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Select the appropriate architectural style (Monolith, Modular Monolith, Microservices).&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;API Design&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Define clear, consistent, and versionable service interfaces.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Database Design:&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Select suitable data stores and design schemas based on access patterns and consistency requirements.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Caching Strategy&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Define caching layers to reduce latency and improve performance.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Asynchronous Processing&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Use queues, events, and background workers for long-running or decoupled tasks.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Scalability&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Design for horizontal scaling, load balancing, and stateless services.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Security&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Address authentication, authorization, encryption, input validation, rate limiting, and secure communication.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;b&gt;Observability:&lt;/b&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;Include logging, metrics, distributed tracing, monitoring, and alerting.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Resilience&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Plan for failures using retries, timeouts, circuit breakers, failover, and disaster recovery.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Deployment &amp;amp; Infrastructure&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Define deployment strategy, CI/CD, infrastructure, networking, and configuration management.&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 19px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); line-height: 170%;&quot; face=&quot;Helvetica&quot;&gt;&lt;b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;Operations &amp;amp; Evolution&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;:&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Support monitoring, maintenance, optimization, scaling, and architectural evolution over time.&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
